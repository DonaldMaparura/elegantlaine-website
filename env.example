# Copy to .env — never commit .env
PORT=8787

# Storefront URL (return/cancel after PayFast)
STORE_URL=https://your-domain.co.za

# Public URL of this API (PayFast ITN notify_url). Same as STORE_URL if you reverse-proxy /api to Node.
API_PUBLIC_URL=https://your-domain.co.za

PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
# true = sandbox.payfast.co.za (testing only)
PAYFAST_SANDBOX=false
